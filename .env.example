# Sao chép: copy .env.example .env
# Production: BẮT BUỘC đặt API_KEY (≥8 ký tự)

NODE_ENV=production
PORT=3001
HOST=127.0.0.1
# HOST=0.0.0.0  # chỉ khi cần LAN + firewall đã cấu hình

# Bảo mật — tạo key ngẫu nhiên, ví dụ: openssl rand -hex 24
API_KEY=change-me-to-a-long-random-secret-key

ADB_PATH=

# Worker
POLL_INTERVAL_MS=5000
JOB_COOLDOWN_MS=30000
# Khoảng cách mặc định giữa các bài đăng (phút) — 0 = không tự xếp cách
DEFAULT_POST_INTERVAL_MIN=0
DEVICE_STALE_MS=900000
HEARTBEAT_INTERVAL_MS=10000

# Media / publish verify
MEDIA_CACHE_TTL_MS=8000
SAW_POSTING_MIN_POLLS=2

# Treo tương tác (xem video + thả tim)
ENGAGE_DURATION_MINUTES=10
ENGAGE_LIKE_RATIO=0.55
ENGAGE_WATCH_MIN_SEC=5
ENGAGE_WATCH_MAX_SEC=22
ENGAGE_MAX_VIDEOS=40
ENGAGE_PROFILE_RATIO=0.14
ENGAGE_COMMENT_VIEW_RATIO=0.2
ENGAGE_COMMENT_POST_RATIO=0.07
ENGAGE_COMMENT_LIKE_RATIO=0.1
ENGAGE_PAUSE_RATIO=0.12
ENGAGE_PASSIVE_RATIO=0.18
ENGAGE_MAX_ACTIONS_PER_VIDEO=2
ENGAGE_MIN_ACTION_GAP_SEC=2.5
ENGAGE_MIN_LIKE_GAP_SEC=8

# Rate limit
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_READ_MAX=300
RATE_LIMIT_WRITE_MAX=40

# Backup & cleanup
BACKUP_INTERVAL_MS=21600000
BACKUP_KEEP_COUNT=14
CLEANUP_INTERVAL_MS=3600000
ARTIFACT_RETENTION_DAYS=7
MAX_SCREENSHOT_FILES=500
MAX_LOG_FILE_BYTES=2097152

# Reverse proxy (nginx) — set 1 nếu đứng sau proxy
# TRUST_PROXY=1
